{
  "name": "personalization-webcomponents",
  "version": "1.2.1",
  "type": "module",
  "private": true,
  "license": "MIT",
  "engines": {
    "node": ">=22.14 <=24"
  },
  "scripts": {
    "dev": "vite",
    "test": "vitest run",
    "build": "vue-tsc --build --noCheck && vite build && npm run post-build",
    "post-build": "node ./processes/PostBuild.js && cyclonedx-npm --omit dev --omit optional --output-reproducible -o dist/application.cdx.json  --validate",
    "preview": "vite preview",
    "lint": "prettier . --check && eslint . && vue-tsc --build --noEmit",
    "fix": "prettier . --write && eslint . --fix",
    "api-gen:generate": "openapi-generator-cli generate -i ../personalization-service/api-docs.json -g typescript-fetch -o src/api/dbs-clients/generated-p13n-service-api --type-mappings=set=Array"
  },
  "dependencies": {
    "@muenchen/muc-patternlab-vue": "10.0.1",
    "@vueuse/core": "14.3.0",
    "vue": "3.5.39",
    "vue-i18n": "11.4.6",
    "sortablejs": "1.15.7",
    "sortablejs-vue3": "1.3.0"
  },
  "devDependencies": {
    "@cyclonedx/cyclonedx-npm": "5.0.0",
    "@muenchen/prettier-codeformat": "1.0.2",
    "@tsconfig/node-lts": "24.0.0",
    "@types/node": "24.11.2",
    "@vitejs/plugin-vue": "6.0.7",
    "@vue/eslint-config-prettier": "10.2.0",
    "@vue/eslint-config-typescript": "14.9.0",
    "@vue/test-utils": "2.4.11",
    "@vue/tsconfig": "0.9.1",
    "eslint": "9.39.4",
    "eslint-plugin-vue": "10.9.2",
    "jsdom": "29.1.1",
    "prettier": "3.8.5",
    "typescript": "5.9.3",
    "vite": "7.3.6",
    "vite-plugin-vue-devtools": "8.1.5",
    "vitest": "4.1.9",
    "vue-tsc": "3.3.5"
  }
}
